# --- application ---
APP_NAME="Solboards"
ENVIRONMENT=dev

# --- database ---
# SQLite for dev; swap for Postgres in Session 12 (Cloud SQL).
DATABASE_URL=sqlite:///./data/adserver.db

# --- jwt for proof_context ---
# Generate a strong random value for production.
JWT_SERVER_SECRET=replace-me-in-prod
JWT_ALGORITHM=HS256
PROOF_CONTEXT_TTL_SECONDS=3600

# --- auth for publisher ---
PUBLISHER_API_KEY=dev-publisher-key

# --- privy (supplied by user) ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/{app_id}/jwks.json

# --- solana ---
SOLANA_RPC_URL=https://api.devnet.solana.com
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- x402 ---
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=solana-devnet

# --- treasury (populate after running bootstrap_treasury.py in Session 2) ---
TREASURY_WALLET_ID=
TREASURY_WALLET_ADDRESS=
FAUCET_AMOUNT_USDC=100
# Drain ceiling per Privy DID. Once an advertiser has claimed this many USDC
# (pending + confirmed across all calls), /api/faucet returns 429. Manual
# override on the VM: DELETE FROM faucet_claims WHERE advertiser_id='did:privy:...';
FAUCET_LIFETIME_CAP_USDC=100

# --- helper wallets for Circle faucet multiplexing (populate after running
#     bootstrap_helpers.py in Session 12). Comma-separated, order matters
#     (sweep_helpers zips ids+addresses). ---
HELPER_WALLET_IDS=
HELPER_WALLET_ADDRESSES=

# --- demo auto-play (Session 11 add) ---
# Demo-only: if true, a background task fires N plays concurrently every
# AUTO_PLAY_INTERVAL_SECONDS, where N is sampled uniformly from
# [AUTO_PLAY_PLAYS_PER_TICK_MIN, AUTO_PLAY_PLAYS_PER_TICK_MAX]. Plays are
# distributed (with replacement) across active + funded campaigns.
# Calibrate the average (mean × ticks/sec) against the calculator-implied
# rate (screens × plays-per-day / 86400) so the dashboard ticks at roughly
# the rate a real campaign would consume. In production real publishers
# drive /bid + /proof — keep this off.
AUTO_PLAY_ENABLED=true
AUTO_PLAY_INTERVAL_SECONDS=15
AUTO_PLAY_PLAYS_PER_TICK_MIN=5
AUTO_PLAY_PLAYS_PER_TICK_MAX=15
DEMO_PUBLISHER_WALLET=3pMCrwRq5tNy1GdonrPivP389eYjeeoGTiMZDtQmV8W9

# --- batch settlement (Session 16.8) ---
# /proof, simulate-play, and auto-play write a `pending` Settlement row
# and return sub-100ms. A background loop flushes pending rows every
# BATCH_FLUSH_INTERVAL_SECONDS, grouping by (campaign_id, publisher_wallet)
# and emitting ONE Solana USDC transfer per group. Replaces the per-play
# on-chain settlement model that was fragile under devnet RPC rate limits.
# Set BATCH_ENABLED=false to disable the loop (e.g. for e2e_demo.py); /proof
# still writes pending rows but you must call services.batch_settler.flush_all
# manually to settle them. See RUNBOOK "Batch settlement (Session 16.8)".
BATCH_ENABLED=true
BATCH_FLUSH_INTERVAL_SECONDS=5
BATCH_MAX_ROWS_PER_FLUSH=100

# --- GCS creatives bucket (Session 13) ---
# Bucket: uniform bucket-level access + allUsers:objectViewer so the
# returned creative_url is publicly readable. Service account only needs
# roles/storage.objectCreator.
# Path is the path INSIDE the container; docker-compose mounts
# ./backend/.secrets to /app/.secrets read-only.
GCS_BUCKET_NAME=x402-adserver-creatives
GCS_CREDENTIALS_JSON=/app/.secrets/gcs-creatives-sa.json

# --- content moderation via Vertex AI Gemini (Session 19.5) ---
# Dedicated SA `x402-moderation-classifier`, bound only to roles/aiplatform.user
# (least privilege — separate from the GCS uploader SA). Provisioned via the
# RUNBOOK "Content moderation (Vertex AI)" section. MODERATION_ENABLED=false
# short-circuits to instant approve — use for local dev that doesn't need
# Vertex (e.g. e2e_demo.py) and to avoid burning quota on test runs.
MODERATION_ENABLED=true
MODERATION_MODEL=gemini-2.5-flash
VERTEX_PROJECT_ID=x402-494608
VERTEX_LOCATION=us-central1
MODERATION_CREDENTIALS_JSON=/app/.secrets/moderation-classifier-sa.json

# --- demo CPM + protocol fee (Session 15) ---
# CPM is locked server-side — advertisers don't set it. $0.50 USD = $0.0005/play.
# Frequency = OPERATING_HOURS_PER_DAY * PLAYS_PER_HOUR_PER_SCREEN per screen
# per day (12 * 12 = 144 plays/screen/day, one every 5 min).
DEMO_CPM=0.5
OPERATING_HOURS_PER_DAY=12
PLAYS_PER_HOUR_PER_SCREEN=12
PROTOCOL_FEE_PCT=0.025

# Bootstrap via scripts/bootstrap_protocol_revenue.py and paste below. The
# 2.5% protocol fee is auto-transferred from each campaign wallet here right
# after x402 settle confirms.
PROTOCOL_REVENUE_WALLET_ID=
PROTOCOL_REVENUE_WALLET_ADDRESS=
