# --- application ---
APP_NAME="x402 Ad Server"
ENVIRONMENT=dev

# --- database ---
# SQLite for dev; swap for Postgres in Session 12 (Cloud SQL).
DATABASE_URL=sqlite:///./data/adserver.db

# --- jwt for proof_context ---
# Generate a strong random value for production.
JWT_SERVER_SECRET=replace-me-in-prod
JWT_ALGORITHM=HS256
PROOF_CONTEXT_TTL_SECONDS=3600

# --- auth for publisher ---
PUBLISHER_API_KEY=dev-publisher-key

# --- privy (supplied by user) ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/{app_id}/jwks.json

# --- solana ---
SOLANA_RPC_URL=https://api.devnet.solana.com
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- x402 ---
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=solana-devnet

# --- treasury (populate after running bootstrap_treasury.py in Session 2) ---
TREASURY_WALLET_ID=
TREASURY_WALLET_ADDRESS=
FAUCET_AMOUNT_USDC=100

# --- helper wallets for Circle faucet multiplexing (populate after running
#     bootstrap_helpers.py in Session 12). Comma-separated, order matters
#     (sweep_helpers zips ids+addresses). ---
HELPER_WALLET_IDS=
HELPER_WALLET_ADDRESSES=

# --- demo auto-play (Session 11 add) ---
# Demo-only: if true, a background task auto-settles one play on a random
# active + funded campaign every AUTO_PLAY_INTERVAL_SECONDS. In production
# real publishers drive /bid + /proof — keep this off.
AUTO_PLAY_ENABLED=true
AUTO_PLAY_INTERVAL_SECONDS=15
DEMO_PUBLISHER_WALLET=3pMCrwRq5tNy1GdonrPivP389eYjeeoGTiMZDtQmV8W9

# --- GCS creatives bucket (Session 13) ---
# Bucket: uniform bucket-level access + allUsers:objectViewer so the
# returned creative_url is publicly readable. Service account only needs
# roles/storage.objectCreator.
# Path is the path INSIDE the container; docker-compose mounts
# ./backend/.secrets to /app/.secrets read-only.
GCS_BUCKET_NAME=x402-adserver-creatives
GCS_CREDENTIALS_JSON=/app/.secrets/gcs-creatives-sa.json
