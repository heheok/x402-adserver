# Copy to frontend/.env and fill in. Only `VITE_*` vars are exposed to the browser.

# Privy app id — must match the one the backend uses for JWKS verification.
# Get it from https://dashboard.privy.io -> your app -> App settings -> API keys.
VITE_PRIVY_APP_ID=

# Where the browser reaches the backend. Default works with `docker compose up`.
VITE_API_BASE_URL=http://localhost:8000
